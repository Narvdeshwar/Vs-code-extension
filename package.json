{
  "name": "voice-feedback",
  "displayName": "Voice Feedback Extension",
  "description": "A VS Code extension that provides voice feedback based on terminal command success or failure.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "voice-feedback.toggle",
        "title": "Voice Feedback: Toggle Enabled/Disabled"
      }
    ],
    "configuration": {
      "title": "Voice Feedback",
      "properties": {
        "voiceFeedback.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable voice feedback."
        },
        "voiceFeedback.successMessage": {
          "type": "string",
          "default": "Hari Ommm",
          "description": "Message to speak on command success."
        },
        "voiceFeedback.failureMessage": {
          "type": "string",
          "default": "Aadi ye kya ho gya aadi",
          "description": "Message to speak on command failure (not used when audio files are present)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/vscode": "^1.84.0",
    "@typescript-eslint/eslint-plugin": "^5.31.0",
    "@typescript-eslint/parser": "^5.31.0",
    "eslint": "^8.20.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {}
}
